generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ==================== RBAC 核心 ====================

// 租户模型
model Tenant {
  id        Int       @id @default(autoincrement())
  name      String
  code      String    @unique
  isEnabled Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  users            User[]
  roles            Role[]
  menus            Menu[]
  systemSettings  SystemSetting[]
  dictionaryTypes DictionaryType[]
  dictionaryItems DictionaryItem[]
  operationLogs   OperationLog[]
  loginLogs       LoginLog[]
  uploadRecords   UploadRecord[]

  @@index([deletedAt])
  @@index([isEnabled])
}

// 用户模型
model User {
  id        Int       @id @default(autoincrement())
  tenantId  Int
  username  String
  email     String?
  password  String
  name      String?
  avatarUrl String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime? // 软删除标记

  tenant    Tenant    @relation(fields: [tenantId], references: [id])
  // 用户与角色多对多关系
  roles     Role[]    @relation("UserRoles")

  @@unique([tenantId, username])
  @@unique([tenantId, email])
  @@index([tenantId])
  @@index([deletedAt])
}

// 角色模型
model Role {
  id          Int       @id @default(autoincrement())
  tenantId    Int
  name        String
  code        String
  description String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime? // 软删除标记

  tenant      Tenant    @relation(fields: [tenantId], references: [id])
  // 角色与用户多对多关系
  users       User[]    @relation("UserRoles")
  // 角色与菜单多对多关系
  menus       Menu[]    @relation("RoleMenus")

  @@unique([tenantId, name])
  @@unique([tenantId, code])
  @@index([tenantId])
  @@index([deletedAt])
}

// 菜单模型（树形结构）
model Menu {
  id          Int       @id @default(autoincrement())
  tenantId    Int
  name        String
  path        String?
  icon        String?
  component   String?
  redirect    String?
  permission  String?
  parentId    Int?
  order       Int       @default(0)
  hidden      Boolean   @default(false)
  type        String    @default("menu") // menu | button | iframe
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime? // 软删除标记

  tenant      Tenant    @relation(fields: [tenantId], references: [id])
  // 自引用关系（树形）
  parent      Menu?     @relation("MenuTree", fields: [parentId], references: [id])
  children    Menu[]    @relation("MenuTree")

  // 角色与菜单多对多关系
  roles       Role[]    @relation("RoleMenus")

  @@index([tenantId])
  @@index([deletedAt])
  @@index([permission])
}

// ==================== 系统设施 ====================

// 系统配置 KV
model SystemSetting {
  id          Int       @id @default(autoincrement())
  tenantId    Int
  key         String
  name        String
  value       Json
  category    String?
  description String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  tenant      Tenant    @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, key])
  @@index([tenantId])
}

// 数据字典类型
model DictionaryType {
  id          Int       @id @default(autoincrement())
  tenantId    Int
  name        String
  code        String
  description String?
  isEnabled   Boolean   @default(true)
  sort        Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  tenant      Tenant    @relation(fields: [tenantId], references: [id])
  items       DictionaryItem[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@index([deletedAt])
  @@index([isEnabled])
  @@index([sort])
}

// 数据字典项
model DictionaryItem {
  id          Int            @id @default(autoincrement())
  tenantId    Int
  typeId      Int
  label       String
  value       String
  color       String?
  isEnabled   Boolean        @default(true)
  sort        Int            @default(0)
  remark      String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  deletedAt   DateTime?

  tenant      Tenant         @relation(fields: [tenantId], references: [id])
  type        DictionaryType @relation(fields: [typeId], references: [id])

  @@index([tenantId])
  @@index([typeId])
  @@index([deletedAt])
  @@index([isEnabled])
  @@index([sort])
}

// 操作日志
model OperationLog {
  id          Int       @id @default(autoincrement())
  tenantId    Int
  userId      Int?
  username    String?
  action      LogAction
  module      String?
  target      String?
  targetId    String?
  targetType  String?
  description String?
  method      String?
  path        String?
  ip          String?
  userAgent   String?
  statusCode  Int?
  duration    Int?      // 耗时 ms
  requestBody String?
  oldValue    Json?
  newValue    Json?
  response    String?
  error       String?
  createdAt   DateTime  @default(now())

  tenant      Tenant    @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([userId])
  @@index([createdAt])
  @@index([module])
}

// 登录日志
model LoginLog {
  id        Int          @id @default(autoincrement())
  tenantId  Int
  userId    Int?
  username  String?
  type      LoginLogType
  ip        String?
  userAgent String?
  success   Boolean      @default(true)
  message   String?
  createdAt DateTime     @default(now())

  tenant    Tenant       @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([userId])
  @@index([createdAt])
}

// 上传记录
model UploadRecord {
  id           Int      @id @default(autoincrement())
  tenantId     Int
  userId       Int?
  username     String?
  originalName String
  storedName   String
  mimeType     String?
  size         Int?     // bytes
  bucket       String?
  objectKey    String?
  url          String?
  module       String?
  refId        String?
  refType      String?
  status       String?
  createdAt    DateTime @default(now())

  tenant       Tenant   @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([userId])
  @@index([createdAt])
  @@index([module])
  @@index([refId])
}

// ==================== 枚举 ====================

enum LogAction {
  CREATE
  UPDATE
  DELETE
  LOGIN
  LOGOUT
  EXPORT
  IMPORT
  OTHER
}

enum LoginLogType {
  LOGIN
  LOGOUT
  REFRESH
  REGISTER
}
