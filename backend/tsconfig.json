{
  "compilerOptions": {
    "module": "commonjs",
    "declaration": true,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "target": "ES2021",
    "sourceMap": true,
    "outDir": "./dist",
    "baseUrl": "./",
    "incremental": true,
    "skipLibCheck": true,
    "strictNullChecks": true,
    "noImplicitAny": false,
    "strictBindCallApply": false,
    "forceConsistentCasingInFileNames": false,
    "noFallthroughCasesInSwitch": false,
    "paths": {
      "@/*": ["src/*"],
      "@/applications/*": ["src/applications/*"],
      "@/infrastructure/*": ["src/infrastructure/*"],
      "@/domains/*": ["src/domains/*"],
      "@/mall/*": ["src/applications/mall/*"],
      "@/prisma/*": ["src/infrastructure/prisma/*"],
      "@/minio/*": ["src/infrastructure/minio/*"],
      "@/redis/*": ["src/infrastructure/redis/*"],
      "@/icon-assets/*": ["src/infrastructure/icon-assets/*"],
      "@/auth/*": ["src/domains/auth/*"],
      "@/users/*": ["src/domains/users/*"],
      "@/roles/*": ["src/domains/roles/*"],
      "@/menus/*": ["src/domains/menus/*"],
      "@/units/*": ["src/domains/units/*"],
      "@/categories/*": ["src/domains/categories/*"],
      "@/brands/*": ["src/domains/brands/*"],
      "@/banners/*": ["src/domains/banners/*"],
      "@/warehouses/*": ["src/domains/warehouses/*"],
      "@/suppliers/*": ["src/domains/suppliers/*"],
      "@/customers/*": ["src/domains/customers/*"],
      "@/products/*": ["src/domains/products/*"],
      "@/inventories/*": ["src/domains/inventories/*"],
      "@/purchases/*": ["src/domains/purchases/*"],
      "@/purchase-receipts/*": ["src/domains/purchase-receipts/*"],
      "@/purchase-returns/*": ["src/domains/purchase-returns/*"],
      "@/orders/*": ["src/domains/orders/*"],
      "@/shipments/*": ["src/domains/shipments/*"],
      "@/sale-returns/*": ["src/domains/sale-returns/*"],
      "@/transfers/*": ["src/domains/transfers/*"],
      "@/adjustments/*": ["src/domains/adjustments/*"],
      "@/payments/*": ["src/domains/payments/*"],
      "@/carts/*": ["src/domains/carts/*"],
      "@/print-templates/*": ["src/domains/print-templates/*"],
      "@/printer-configs/*": ["src/domains/printer-configs/*"],
      "@/printers/*": ["src/domains/printers/*"]
    }
  }
}
